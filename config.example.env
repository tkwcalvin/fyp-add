# ============================================================
# Copy as config.env, then source it or export vars manually.
# This file contains no model weights, only env var definitions.
#
#   cp config.example.env config.env
#   # Edit config.env and fill in your local paths
#   source config.env
# ============================================================

# --- SAM (required) ---
# Segment Anything ViT-H checkpoint:
#   wget https://dl.fbaipublicfiles.com/segment_anything/sam_vit_h_4b8939.pth -O weights/sam_vit_h_4b8939.pth
export SAM_CHECKPOINT="$PWD/weights/sam_vit_h_4b8939.pth"

# --- Stable Diffusion 1.5 (required, choose one) ---
# Option A: point to a **local diffusers snapshot directory** (contains model_index.json)
# export SD_MODEL_ID="$PWD/weights/sd15"
#
# Option B: point to HuggingFace hub repo cache dir (the models--runwayml--stable-diffusion-v1-5 level)
export SD_HUB_REPO_DIR="$HOME/.cache/huggingface/hub/models--runwayml--stable-diffusion-v1-5"

# --- SDXL Inpaint (required) ---
# Local SDXL inpaint snapshot directory (contains model_index.json)
export SDXL_MODEL_DIR="$PWD/weights/sdxl_inpaint"
# Some scripts also read MODEL_DIR; keep it for compatibility:
export MODEL_DIR="$SDXL_MODEL_DIR"

# --- (optional) CLIP rerank: used with --sam-clip-rerank ---
# export SD_SAM_CLIP_MODEL_ID="$PWD/weights/clip"

# --- (optional) HF mirror / download acceleration ---
# export HF_ENDPOINT="https://hf-mirror.com"
# export HF_HUB_ENABLE_HF_TRANSFER=0   # Disable if xet download errors occur

# --- (optional) override auto-detected backend paths ---
# Defaults are ./workflow_backend/ and ./sdxl_inpaint/, usually no need to change
# export WORKFLOW_BACKEND="$PWD/workflow_backend"
# export FYP_ROOT="$PWD/sdxl_inpaint"
