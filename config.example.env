# ============================================================
# 复制为 config.env 后 source，或逐条手动 export。
# 本文件不含任何权重，只是环境变量入口。
#
#   cp config.example.env config.env
#   # 编辑 config.env 填入你本机路径
#   source config.env
# ============================================================

# --- SAM（必填）---
# Segment Anything ViT-H 检查点：
#   wget https://dl.fbaipublicfiles.com/segment_anything/sam_vit_h_4b8939.pth -O weights/sam_vit_h_4b8939.pth
export SAM_CHECKPOINT="$PWD/weights/sam_vit_h_4b8939.pth"

# --- Stable Diffusion 1.5（必填，二选一）---
# 方式 A：指向一个**本地 diffusers snapshot 目录**（内含 model_index.json）
# export SD_MODEL_ID="$PWD/weights/sd15"
#
# 方式 B：指向 HuggingFace hub 缓存中的仓库目录（models--runwayml--stable-diffusion-v1-5 这一层）
export SD_HUB_REPO_DIR="$HOME/.cache/huggingface/hub/models--runwayml--stable-diffusion-v1-5"

# --- SDXL Inpaint（必填）---
# 本地 SDXL inpaint 快照目录（含 model_index.json）
export SDXL_MODEL_DIR="$PWD/weights/sdxl_inpaint"
# 有些脚本也会读 MODEL_DIR，这里保持兼容：
export MODEL_DIR="$SDXL_MODEL_DIR"

# --- （可选）CLIP 重排：开启 --sam-clip-rerank 时用 ---
# export SD_SAM_CLIP_MODEL_ID="$PWD/weights/clip"

# --- （可选）HF 镜像 / 下载加速 ---
# export HF_ENDPOINT="https://hf-mirror.com"
# export HF_HUB_ENABLE_HF_TRANSFER=0   # 遇到 xet 下载报错时可关掉

# --- （可选）覆盖脚本自动探测的 backend 路径 ---
# 默认分别是 ./workflow_backend/ 和 ./sdxl_inpaint/，一般不需要改
# export WORKFLOW_BACKEND="$PWD/workflow_backend"
# export FYP_ROOT="$PWD/sdxl_inpaint"
